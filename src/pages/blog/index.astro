---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/blog/PostList.astro';
import { useTranslations } from '../../i18n';

const T = useTranslations('en');
const allPosts = await getCollection('blogEn', (p) => !p.data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`${T.blog.title} — dumpthecore`}
  description={T.blog.description}
>
  <div style="max-width: 1100px; margin: 0 auto; padding: 3rem 1rem 5rem;">
    <header style="margin-bottom: 3rem;">
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 600; letter-spacing: -0.03em; color: var(--text); margin-bottom: 0.75rem;">
        {T.blog.title}
      </h1>
      <p style="color: var(--text-muted); font-size: 1rem;">
        {T.common.postsAndCounting(sorted.length)}
      </p>
    </header>

    <PostList posts={sorted} columns={2} lang="en" />
  </div>
</BaseLayout>
