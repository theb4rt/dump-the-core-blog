---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostList from '../../../components/blog/PostList.astro';
import { getUniqueCategories } from '../../../utils/taxonomy';
import { useTranslations } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blogEs', (p) => !p.data.draft);
  const categories = getUniqueCategories(posts);

  return categories.map((cat) => ({
    params: { category: cat.toLowerCase().replace(/\s+/g, '-') },
    props: { category: cat },
  }));
}

const T = useTranslations('es');
const { category } = Astro.props;
const allPosts = await getCollection('blogEs', (p) => !p.data.draft && p.data.category === category);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={T.categories.pageTitle(category)}
  description={T.categories.pageDescription(category)}
  lang="es"
>
  <div style="max-width: 1100px; margin: 0 auto; padding: 3rem 1rem 5rem;">
    <div style="margin-bottom: 0.5rem;">
      <a
        href="/es/categories"
        style="font-size: 0.875rem; color: var(--text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem;"
        onmouseover="this.style.color='var(--accent)'"
        onmouseout="this.style.color='var(--text-muted)'"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        {T.categories.back}
      </a>
    </div>
    <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 600; letter-spacing: -0.03em; color: var(--text); margin-bottom: 0.75rem;">
      {category}
    </h1>
    <p style="color: var(--text-muted); margin-bottom: 3rem;">
      {T.common.posts(sorted.length)}
    </p>

    <PostList posts={sorted} columns={2} lang="es" />
  </div>
</BaseLayout>
