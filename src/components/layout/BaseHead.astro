---
import '../../styles/global.css';
import '../../styles/typography.css';
import '../../styles/syntax.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: URL | string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  hreflangAlternate?: { hreflang: string; href: string }[];
}

const {
  title,
  description,
  image = '/og/default.png',
  canonicalURL = Astro.url,
  type = 'website',
  pubDate,
  updatedDate,
  author = 'b4rt',
  tags = [],
  hreflangAlternate,
} = Astro.props;

const siteURL = 'https://dumpthecore.com';
const ogImage = new URL(image, siteURL).href;
const canonical = canonicalURL.toString();

// JSON-LD
const jsonLD = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImage,
      url: canonical,
      datePublished: pubDate?.toISOString(),
      dateModified: (updatedDate ?? pubDate)?.toISOString(),
      author: {
        '@type': 'Person',
        name: author,
        url: `${siteURL}/about`,
      },
      publisher: {
        '@type': 'Organization',
        name: 'dumpthecore',
        url: siteURL,
        logo: {
          '@type': 'ImageObject',
          url: `${siteURL}/favicon.svg`,
        },
      },
      keywords: tags.join(', '),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'dumpthecore',
      url: siteURL,
      description,
      author: {
        '@type': 'Person',
        name: author,
        url: `${siteURL}/about`,
      },
    };
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Theme flash prevention — runs synchronously before paint -->
<script is:inline>
  (function () {
    try {
      const t =
        localStorage.getItem('theme') ??
        (window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light');
      document.documentElement.setAttribute('data-theme', t);
    } catch (_) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>

<!-- Primary -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
<meta name="author" content={author} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="dumpthecore" />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,600;0,700;0,800;0,900;1,700&family=Open+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Inconsolata:wght@400;500;600&display=swap"
/>

<!-- hreflang alternate -->
{hreflangAlternate && hreflangAlternate.map(({ hreflang, href }) => (
  <link rel="alternate" hreflang={hreflang} href={href} />
))}

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="dumpthecore RSS Feed"
  href="/rss.xml"
/>

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
