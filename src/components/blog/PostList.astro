---
import type { CollectionEntry } from 'astro:content';
type AnyPost = CollectionEntry<'blogEn'> | CollectionEntry<'blogEs'>;
import PostCard from './PostCard.astro';

interface Props {
  posts: AnyPost[];
  columns?: 1 | 2 | 3;
  lang?: 'en' | 'es';
}

const { posts, columns = 2, lang } = Astro.props;

const gridCols: Record<number, string> = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
};
---

{posts.length === 0 ? (
  <p style="color: var(--text-muted); text-align: center; padding: 4rem 0;">No posts found.</p>
) : (
  <div class={`grid gap-6 ${gridCols[columns]}`}>
    {posts.map((post) => (
      <PostCard post={post} lang={lang} />
    ))}
  </div>
)}
