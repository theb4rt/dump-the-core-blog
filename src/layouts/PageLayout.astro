---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'es';
}

const { title, description, lang } = Astro.props;
---

<BaseLayout title={`${title} — dumpthecore`} description={description} lang={lang}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">
    <slot />
  </div>
</BaseLayout>
